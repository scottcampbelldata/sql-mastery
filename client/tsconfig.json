{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode: Vite owns the build, tsc only type-checks. */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Incremental migration: tsc reads plain .js modules but only type-checks .ts/.tsx. */
    "allowJs": true,
    "checkJs": false,

    /* Strictness: the reason we are doing this. */
    "strict": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["vitest/globals", "@testing-library/jest-dom", "node"]
  },
  "include": ["src"]
}
