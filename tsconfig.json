{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "declaration": false,
    "sourceMap": false,
    "types": ["node"],
    "allowJs": true,
    "checkJs": false
  },
  "include": ["server.ts", "src/**/*", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "client"]
}
