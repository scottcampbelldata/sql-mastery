PORT=3000
# Bind address. Keep 127.0.0.1 and put a TLS reverse proxy (nginx/Caddy) in front on a VPS;
# use 0.0.0.0 only if you intentionally expose Node directly to the internet.
HOST=127.0.0.1
# Split deployment (e.g. Cloudflare Pages front end): comma-separated front-end origins
# allowed to call this API via CORS. Leave empty for same-origin hosting. "*" allows any.
# Example: https://sql-mastery.pages.dev,https://sqlmastery.example.com
SQL_MASTERY_ALLOWED_ORIGINS=
# Serve the built front end from this backend (all-in-one). Set to false for a split
# deployment where Cloudflare Pages serves the UI and this VPS runs API-only.
SQL_MASTERY_SERVE_CLIENT=true
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
SQL_MASTERY_DATABASES=chinook,stackoverflow
SQL_MASTERY_DATABASE_ALIASES=chinook=chinook_serial,stackoverflow=stackoverflow_dba
SQL_MASTERY_STATEMENT_TIMEOUT_MS=60000
# Google sign-in (accounts + cross-device progress)
GOOGLE_CLIENT_ID=your-oauth-web-client-id.apps.googleusercontent.com
SQL_MASTERY_SESSION_SECRET=change-me-to-a-long-random-string
# Optional: where accounts and progress JSON live (defaults to ./data)
# SQL_MASTERY_DATA_DIR=/home/scott/apps/sql-mastery/data
